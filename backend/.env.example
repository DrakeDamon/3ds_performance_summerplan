# Copy to .env and fill in. NEVER commit .env (already in .gitignore).

# Random long string you make up — protects GET /api/stats
ADMIN_TOKEN=change-me-to-a-long-random-string

# Comma-separated origins allowed to call this API
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# SQLite analytics file location
ANALYTICS_DB=analytics.db

# Optional, only if you later add server-side Stripe calls.
# Use a RESTRICTED key. Not required for payment links to work.
# STRIPE_SECRET_KEY=rk_live_xxx
